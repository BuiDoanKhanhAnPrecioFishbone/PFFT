    <style rel="stylesheet" crossorigin>*{box-sizing:border-box;margin:0;padding:0}body{font-family:Inter,-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;font-size:12px;color:#1e1e1e;background:#fff;overflow:hidden}.app{display:flex;flex-direction:column;height:560px;padding:16px;gap:12px}.header{display:flex;align-items:center;gap:8px}.header-logo{font-size:16px}.header-title{font-size:14px;font-weight:600;color:#1e1e1e}.header-badge{font-size:10px;font-weight:500;color:#6e6e6e;background:#f4f4f4;border-radius:4px;padding:1px 5px}.section-label{font-size:11px;font-weight:600;color:#6e6e6e;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}.key-row{display:flex;gap:6px;align-items:center}.key-input{flex:1;font-size:12px;font-family:Courier New,monospace;border:1px solid #e5e5e5;border-radius:6px;padding:6px 10px;outline:none;background:#fafafa;transition:border-color .15s}.key-input:focus{border-color:#1659e6;background:#fff}.key-saved-pill{font-size:11px;color:#2da051;font-weight:500;white-space:nowrap}.code-area{flex:1;display:flex;flex-direction:column;min-height:0}.code-textarea{flex:1;width:100%;font-size:11px;font-family:Courier New,monospace;line-height:1.5;border:1px solid #e5e5e5;border-radius:6px;padding:10px;outline:none;resize:none;background:#fafafa;transition:border-color .15s;min-height:180px}.code-textarea:focus{border-color:#1659e6;background:#fff}.code-textarea::placeholder{color:#aaa}.status-banner{border-radius:6px;padding:8px 12px;font-size:12px;line-height:1.4}.status-banner.progress{background:#f0f4ff;color:#1659e6;border:1px solid #c9d9fc}.status-banner.success{background:#f0fff4;color:#2da051;border:1px solid #b7ebc8}.status-banner.error{background:#fff0f0;color:#d04040;border:1px solid #f5c2c2;white-space:pre-wrap;word-break:break-word;max-height:100px;overflow-y:auto}.status-banner.warning{background:#fffbeb;color:#92400e;border:1px solid #fcd34d;font-size:11px;line-height:1.5}.toggle-advanced{background:none;border:none;cursor:pointer;font-size:11px;color:#6e6e6e;padding:0;text-decoration:underline;text-underline-offset:2px}.toggle-advanced:hover{color:#1e1e1e}.tailwind-textarea{width:100%;font-size:11px;font-family:Courier New,monospace;border:1px solid #e5e5e5;border-radius:6px;padding:8px 10px;outline:none;resize:vertical;background:#fafafa;height:72px}.tailwind-textarea:focus{border-color:#1659e6;background:#fff}.convert-btn{width:100%;background:#1659e6;color:#fff;border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .15s,opacity .15s}.convert-btn:hover:not(:disabled){background:#1148c2}.convert-btn:disabled{opacity:.55;cursor:not-allowed}.spinner{width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.footer{font-size:10px;color:#b0b0b0;text-align:center}.batch-toggle-row{display:flex;align-items:center;gap:10px}.batch-toggle-label{display:flex;align-items:center;font-size:12px;font-weight:500;color:#1e1e1e;cursor:pointer;user-select:none}.batch-hint{font-size:10px;color:#6e6e6e}.batch-hint code{background:#f4f4f4;border-radius:3px;padding:1px 4px;font-family:JetBrains Mono,Fira Code,Menlo,monospace;font-size:10px}.batch-count-hint{font-size:10px;color:#6e6e6e;margin-top:4px}</style>
  </head>
  <body>
    <div id="root"></div>
  </body>
</html>

