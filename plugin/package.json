{
  "name": "code-to-figma-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:code\"",
    "dev:ui": "vite build --watch",
    "dev:code": "esbuild src/code.ts --bundle --target=es2017 --outfile=code.js --watch",
    "build": "npm run build:ui && npm run build:code",
    "build:ui": "vite build",
    "build:code": "esbuild src/code.ts --bundle --target=es2017 --outfile=code.js",
    "typecheck": "tsc --noEmit --project tsconfig.code.json && tsc --noEmit --project tsconfig.ui.json",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.92.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
